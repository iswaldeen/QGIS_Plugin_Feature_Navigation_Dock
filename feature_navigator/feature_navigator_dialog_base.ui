  <property name="styleSheet">
   <string notr="true">/* Keep the overall green identity without forcing editor/control colours.
   Input widgets, checkboxes, and their text are intentionally left to the
   active QGIS/Qt palette so they remain light in QGIS 3 light themes and dark
   in QGIS 4 / Qt6 dark themes. */
QDialog#FeatureNavigatorSettingsDialogBase {
    background-color: palette(window);
}

QFrame#headerFrame {
    background-color: #c0e1c0;
    border-radius: 12px;
}

QFrame#settingsCard {
    border: 1px solid #b8d8bd;
    border-radius: 12px;
    background-color: palette(base);
}

QLabel#titlelabel {
    color: #1f4f32;
    font-size: 18px;
    font-weight: 600;
    background: transparent;
}

QLabel#subtitleLabel {
    color: #2f5f40;
    font-size: 10pt;
    background: transparent;
}

QGroupBox {
    font-weight: 600;
    border: 1px solid #9fcda6;
    border-radius: 10px;
    margin-top: 18px;
    padding: 12px 10px 8px 10px;
    background: transparent;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    top: 2px;
    padding: 0 6px;
    color: #2f7d50;
    background-color: palette(base);
}

QLabel#optionsDescriptionLabel,
QLabel#valuesDescriptionLabel {
    font-size: 9pt;
}


QDialogButtonBox QPushButton {
    min-width: 78px;
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid #8fbd97;
    background-color: #e8f5e9;
    color: #214b35;
}

QDialogButtonBox QPushButton:hover {
    background-color: #d7edd8;
}

QDialogButtonBox QPushButton:pressed {
    background-color: #c4e3c6;
}</string>
